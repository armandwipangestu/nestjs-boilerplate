{
  "title": "NestJS Boilerplate - Application Metrics",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Request Rate (RPS)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_count[1m]))",
          "legendFormat": "RPS"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Error Rate (4xx + 5xx)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_count{http_status_code=~\"4..|5..\"}[1m]))",
          "legendFormat": "Errors/sec"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Event Loop Utilization",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "nodejs_eventloop_utilization",
          "legendFormat": "ELU"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Latency (P50 / P90 / P99)",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_duration_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(http_server_duration_bucket[5m])) by (le))",
          "legendFormat": "P90"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_duration_bucket[5m])) by (le))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Rate by Route",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_count[1m])) by (http_route)",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate by Status Code",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_count{http_status_code=~\"4..|5..\"}[1m])) by (http_status_code)",
          "legendFormat": "{{http_status_code}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Outbound HTTP Latency (P95)",
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_client_duration_bucket[5m])) by (le))",
          "legendFormat": "Client P95"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Event Loop Delay (p99)",
      "gridPos": { "x": 0, "y": 29, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "nodejs_eventloop_delay_p99",
          "legendFormat": "EL Delay p99"
        }
      ]
    }
  ]
}